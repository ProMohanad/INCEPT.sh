# slots_compare_files.gbnf — constrain slot-filling output for compare_files intent
root ::= slot-file1 "\n" slot-file2 optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-file1 ::= "file1=" path-value
slot-file2 ::= "file2=" path-value

optional-slot ::= slot-context-lines

slot-context-lines ::= "context_lines=" number

path-value ::= "/" [a-zA-Z0-9_./-]* | "."
number     ::= [0-9]+
