# slots_delete_files.gbnf — constrain slot-filling output for delete_files intent
root ::= slot-target optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-target ::= "target=" path-value

optional-slot ::= slot-recursive | slot-force

slot-recursive ::= "recursive=" bool-value
slot-force     ::= "force=" bool-value

path-value ::= "/" [a-zA-Z0-9_./-]* | "."
bool-value ::= "true" | "false"
