# slots_extract_columns.gbnf — constrain slot-filling output for extract_columns intent
root ::= slot-field-spec optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-field-spec ::= "field_spec=" quoted-string

optional-slot ::= slot-input-file | slot-delimiter

slot-input-file ::= "input_file=" path-value
slot-delimiter  ::= "delimiter=" quoted-string

path-value     ::= "/" [a-zA-Z0-9_./-]* | "."
quoted-string  ::= "\"" [^\"]* "\""
