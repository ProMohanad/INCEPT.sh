# slots_kill_process.gbnf — constrain slot-filling output for kill_process intent
root ::= slot-target optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-target ::= "target=" target-value

optional-slot ::= slot-signal | slot-force

slot-signal ::= "signal=" identifier
slot-force  ::= "force=" bool-value

target-value ::= identifier | number

identifier ::= [a-zA-Z_] [a-zA-Z0-9_.-]*
number     ::= [0-9]+
bool-value ::= "true" | "false"
