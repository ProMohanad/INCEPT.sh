# slots_process_list.gbnf — constrain slot-filling output for process_list intent
root ::= slot-list
slot-list ::= slot ("\n" slot)*

slot ::= slot-filter | slot-sort-by | slot-user

slot-filter  ::= "filter=" quoted-string
slot-sort-by ::= "sort_by=" sort-value
slot-user    ::= "user=" identifier

sort-value ::= "cpu" | "memory" | "pid" | "name"

identifier    ::= [a-zA-Z_] [a-zA-Z0-9_.-]*
quoted-string ::= "\"" [^\"]* "\""
