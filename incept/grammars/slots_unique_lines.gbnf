# slots_unique_lines.gbnf — constrain slot-filling output for unique_lines intent
root ::= slot-list
slot-list ::= slot ("\n" slot)*

slot ::= slot-input-file | slot-count | slot-only-duplicates

slot-input-file     ::= "input_file=" path-value
slot-count          ::= "count=" bool-value
slot-only-duplicates ::= "only_duplicates=" bool-value

path-value ::= "/" [a-zA-Z0-9_./-]* | "."
bool-value ::= "true" | "false"
